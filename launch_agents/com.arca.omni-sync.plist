<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.arca.omni-sync</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Library/Frameworks/Python.framework/Versions/3.13/bin/python3</string>
        <string>/Users/danexall/omni_sync.py</string>
        <string>--config</string>
        <string>/Users/danexall/omni_sync_config.json</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/Users/danexall</string>
    <key>RunAtLoad</key>
    <true/>
