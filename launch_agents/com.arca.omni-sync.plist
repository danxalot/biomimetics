    <string>/Users/danexall/.arca/omni_sync.err</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONUNBUFFERED</key>
        <string>1</string>
        <key>PYTHONIOENCODING</key>
        <string>UTF-8</string>
    </dict>
</dict>
</plist>
