# Gemini Relay Environment Configuration
# Copy this file to /etc/gemini_relay.env and edit with your actual values
#
# Usage:
#   sudo cp gemini_relay.env /etc/gemini_relay.env
#   sudo nano /etc/gemini_relay.env

# =============================================================================
# Gemini API Configuration
# =============================================================================

# Option 1: Direct API key (simplest)
GEMINI_API_KEY=

# Option 2: Azure Key Vault (recommended for production)
AZURE_KEY_VAULT_NAME=arca-mcp-kv-dae
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
GEMINI_SECRET_NAME=gemini-api-key

# =============================================================================
# Muninn Memory Spooler
# =============================================================================

# URL to POST transcript data (optional)
# Example: http://10.128.0.3/api/engrams
MUNINN_URL=http://10.128.0.3/api/engrams

# =============================================================================
# Relay Configuration
# =============================================================================

# Host to bind (0.0.0.0 = all interfaces)
RELAY_HOST=0.0.0.0

# Port for WebSocket relay
RELAY_PORT=8765
