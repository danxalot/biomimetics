    "name": "read_file",
    "description": "Read the contents of any file on the system. Use to inspect code, configs, logs.",
    "parameters": {
        "type": "object",
        "properties": {
            "path": {
                "type": "string",
                "description": "Absolute path to the file to read",
            },
            "max_lines": {
                "type": "integer",
                "description": "Max lines to return (default 100)",
            },
        },
