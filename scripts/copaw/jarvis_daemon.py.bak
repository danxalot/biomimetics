    },
}

write_file_tool = {
    "name": "write_file",
    "description": "Write or overwrite a file. Use to fix code, update configs. ALWAYS read the file first.",
    "parameters": {
        "type": "object",
        "properties": {
            "path": {
                "type": "string",
